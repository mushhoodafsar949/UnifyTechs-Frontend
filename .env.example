# Base URL of the UnifyTechs.Api backend.
#
# Leave EMPTY in development — `src/config.ts` falls back to same-origin so
# Vite's dev proxy (see `vite.config.ts`) forwards `/api/*` to http://localhost:5183.
#
# Set this in production / preview deployments when the SPA is hosted on a
# different origin from the API (e.g. Vercel + Azure App Service).
# The value must NOT include a trailing slash — the client appends `/api/...`.
#
# Examples:
#   VITE_API_URL=https://api.unifytechs.us
#   VITE_API_URL=http://localhost:5183
VITE_API_URL=
